# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...         # Claude API — all agent reasoning
OPENAI_API_KEY=sk-...                # Whisper transcription + text-embedding-3-small

# ── Optional: Vector Memory (Pinecone) ────────────────────────────────────────
# Leave blank to use the in-memory mock store (works fine for demos)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=meeting-memory

# ── Optional: Slack Integration ───────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0123456789

# ── Optional: LangSmith Observability ────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-meeting-copilot
LANGCHAIN_TRACING_V2=true

# ── App Config ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
UPLOAD_DIR=/tmp/meeting-uploads
